# ── Core ──────────────────────────────────
# PICOCLAW_HOME=~/.picoclaw
# PICOCLAW_CONFIG=~/.picoclaw/config.json

# ── Agent Defaults ────────────────────────
# PICOCLAW_AGENTS_DEFAULTS_MODEL=openai/gpt-4o
# PICOCLAW_AGENTS_DEFAULTS_WORKSPACE=~/.picoclaw/workspace

# ── LLM Provider ──────────────────────────
# Uncomment and set the API key for your provider
# PICOCLAW_PROVIDERS_OPENROUTER_API_KEY=sk-or-v1-xxx
# PICOCLAW_PROVIDERS_ZHIPU_API_KEY=xxx
# PICOCLAW_PROVIDERS_ANTHROPIC_API_KEY=sk-ant-xxx
# PICOCLAW_PROVIDERS_OPENAI_API_KEY=sk-xxx
# PICOCLAW_PROVIDERS_GEMINI_API_KEY=xxx
# PICOCLAW_PROVIDERS_DEEPSEEK_API_KEY=sk-xxx
# PICOCLAW_PROVIDERS_VOLCENGINE_API_KEY=sk-xxx

# ── Chat Channel ──────────────────────────
# PICOCLAW_CHANNELS_TELEGRAM_TOKEN=123456:ABC...
# PICOCLAW_CHANNELS_DISCORD_TOKEN=xxx

# ── Web Search (optional) ────────────────
# PICOCLAW_TOOLS_WEB_BRAVE_API_KEY=BSA...
# PICOCLAW_TOOLS_WEB_TAVILY_API_KEY=tvly-...

# ── Timezone ──────────────────────────────
TZ=Asia/Shanghai
